{
  "compilerOptions": {
    "composite": true,
    "target": "ES2024",
    "lib": ["ES2024"],
    "skipLibCheck": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "playwright.config.ts"]
}
