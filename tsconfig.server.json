{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "rootDir": ".",
    "outDir": "server-dist",
    "types": ["node"]
  },
  "include": ["server/index.ts", "shared/**/*.ts"]
}
